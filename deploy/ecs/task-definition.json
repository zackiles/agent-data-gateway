{
  "family": "agent-data-gateway",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "EXECUTION_ROLE_ARN_PLACEHOLDER",
  "containerDefinitions": [
    {
      "name": "agent-data-gateway",
      "image": "IMAGE_PLACEHOLDER",
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "SCRUBBER_ADAPTER", "value": "trusted-header" },
        { "name": "SCRUBBER_INDEX", "value": "/data/example-index.json" },
        { "name": "SCRUBBER_POLICY", "value": "/data/example-policy.json" },
        { "name": "SCRUBBER_PORT", "value": "8080" },
        { "name": "SCRUBBER_HEADER_USER", "value": "X-Amzn-Oidc-Data" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/agent-data-gateway",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
